@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto text-xs leading-tight">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-lg" style="animation: mc-place 0.3s ease-out;">⛏️</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetBlockClass()
    {
        if (Square.IsFreeSpace) return "mc-grass-block";
        
        return (Square.Id % 4) switch
        {
            0 => "mc-grass-block",
            1 => "mc-dirt-block",
            2 => "mc-stone-block",
            _ => "mc-diamond-block"
        };
    }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-2 text-center border-2 select-none min-h-[70px] mc-block font-bold";
        var blockClass = GetBlockClass();
        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "animate-mc-break"
                : "opacity-90 scale-95"
            : "";

        return $"{baseClasses} {blockClass} {stateClasses}";
    }
}
